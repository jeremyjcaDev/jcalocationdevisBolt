# Configuration API
# Choisissez le mode : 'prestashop' ou 'supabase'
VITE_API_MODE=supabase

# Configuration PrestaShop (si VITE_API_MODE=prestashop)
VITE_PRESTASHOP_API_URL=https://votre-site.com/modules/jca_locationdevis/api
VITE_PRESTASHOP_TOKEN=votre-token-prestashop

# Configuration Supabase (si VITE_API_MODE=supabase)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
